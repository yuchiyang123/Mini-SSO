# 複製這個檔案為 .env（不要提交到 git），並填入實際的值。
# docker-compose up -d 會自動讀取同目錄下的 .env。

# ---- SQL Server ----
# db 容器的 sa 密碼，需符合 SQL Server 密碼複雜度規則（大小寫+數字+符號，至少 8 碼）。
SA_PASSWORD=Your_strong_password123!

# ---- JWT（內部帳密登入 & SSO 登入共用） ----
JWT_KEY=please-change-to-a-random-32+char-secret
JWT_ISSUER=yourdomain.com
JWT_AUDIENCE=yourdomain.com
JWT_EXPIRE_MINUTES=60
# refresh token（存在 Redis）的有效天數，過期後要重新登入
JWT_REFRESH_EXPIRE_DAYS=30

# ---- Google OAuth ----
# 申請位置：https://console.cloud.google.com/apis/credentials
# 建立「OAuth 用戶端 ID」(網頁應用程式)，Redirect URI 填：
#   https://<你的網域>/signin-google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- GitHub OAuth ----
# 申請位置：https://github.com/settings/developers -> OAuth Apps -> New OAuth App
# Authorization callback URL 填：
#   https://<你的網域>/signin-github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- 前端 ----
# SSO 登入成功後導回的前端網址
FRONTEND_REDIRECT_URL=http://localhost:3000/sso/callback

# 允許呼叫這組 API 的前端網域（CORS），多個網域用逗號分隔，例如：
#   CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
